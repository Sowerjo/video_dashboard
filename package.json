{
  "name": "video-dashboard-app",
  "version": "1.0.0",
  "description": "Aplicativo desktop Mind Flix para reprodução de IPTV e vídeos locais",
  "main": "main.js",
  "author": "Mind Flix",
  "license": "MIT",
  "dependencies": {
    "bonjour-service": "1.3.0",
    "castv2-client": "1.2.0",
    "electron-store": "8.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-icons": "^5.5.0",
    "react-player": "^3.4.0",
    "styled-components": "^6.1.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.4",
    "electron": "^38.1.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "scripts": {
    "start": "webpack --watch",
    "build-renderer": "webpack",
    "build": "webpack",
    "electron": "electron .",
    "build-ico": "node scripts/build-ico.js",
    "dist": "gerar-instalador.bat",
    "git-automation": "bash ./automacao-git-final.sh"
  },
  "build": {
    "appId": "com.jogus.videodashboard",
    "productName": "Mind Flix",
    "directories": {
      "output": "dist"
    },
    "files": [
      "public/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "assets/**/*",
      "icon.ico",
      "cadeado_closed.png",
      "cadeado_aberto.png"
    ],
    "extraFiles": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "copyright": "Copyright © 2026 Mind Flix",
    "win": {
      "icon": "icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/installer.ico",
      "uninstallerIcon": "assets/uninstaller.ico"
    }
  }
}
